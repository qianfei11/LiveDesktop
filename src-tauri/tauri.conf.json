{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LivePhoto Viewer",
  "version": "0.1.0",
  "identifier": "com.livephoto.viewer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LivePhoto Viewer",
        "width": 1280,
        "height": 820,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png"],
    "category": "Photography",
    "shortDescription": "View Live Photos (JPEG+MOV pairs) across platforms"
  }
}
